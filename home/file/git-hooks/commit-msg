#!/usr/bin/env bash
#
# Global commit-msg hook -- mechanical validation of commit messages.
# Canonical source for these rules: ~/.cursor/skills/commit-conventions/SKILL.md
# and ~/.cursor/skills/writing-style/SKILL.md
#
# Deployed to ~/.config/git/hooks/commit-msg via home-manager.
# If a repo-local .git/hooks/commit-msg exists, it is chained after this hook.

set -euo pipefail

msg_file="$1"
msg=$(cat "$msg_file")
subject=$(head -1 "$msg_file")

errors=()

# --- Strip IDE-injected AI trailers (Cursor, Copilot, etc.) ---
perl -i -ne 'print unless /^Co-authored-by:\s*(cursor|copilot|ai)/i || /^(Generated by|AI-generated)/i' "$msg_file"
msg=$(cat "$msg_file")
subject=$(head -1 "$msg_file")

# --- Subject line length ---
if [ "${#subject}" -gt 72 ]; then
  errors+=("Subject line exceeds 72 characters (currently ${#subject}).")
fi

# --- No exclamation marks in subject ---
if echo "$subject" | grep -qF '!'; then
  errors+=("Subject line contains an exclamation mark.")
fi

# --- Banned LLM vocabulary ---
banned='delve|leverage|utilize|robust|comprehensive|nuanced|pivotal|seamless|holistic|multifaceted|cutting-edge|transformative|foster|harness|empower|spearhead|bolster|landscape|tapestry|realm|paradigm|synergy|ecosystem|cornerstone|trajectory|confluence|plethora|myriad'
matched=$(echo "$msg" | grep -oiE "$banned" | head -5 || true)
if [ -n "$matched" ]; then
  words=$(echo "$matched" | tr '\n' ', ' | sed 's/, $//')
  errors+=("Banned LLM vocabulary found: $words")
fi

# --- Typographic characters (non-ASCII dashes, curly quotes) ---
if printf '%s' "$msg" | perl -CSD -0777 -ne 'exit 0 if /[\x{2013}\x{2014}\x{2018}\x{2019}\x{201c}\x{201d}\x{2022}\x{00b7}]/; exit 1'; then
  errors+=("Non-ASCII typographic characters detected (em-dash, curly quotes, etc.) -- use keyboard ASCII only.")
fi

# --- Report errors ---
if [ ${#errors[@]} -gt 0 ]; then
  echo ""
  echo "commit-msg hook: commit blocked."
  echo ""
  for e in "${errors[@]}"; do
    echo "  - $e"
  done
  echo ""
  echo "Fix the message and try again."
  exit 1
fi

# --- Chain to repo-local hook if present ---
repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [ -n "$repo_root" ] && [ -x "$repo_root/.git/hooks/commit-msg" ]; then
  exec "$repo_root/.git/hooks/commit-msg" "$@"
fi

exit 0
